    "format": "prettier --write 'src/**/*.{ts,tsx,css,html}'",
    "validate": "office-addin-manifest validate manifest.xml"
  },
  "dependencies": {
    "core-js": "^3.36.0"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.430",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^7.0.0",
    "eslint": "^9.0.0",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^5.0.0",
    "office-addin-dev-certs": "^1.12.0",
    "office-addin-manifest": "^1.13.0",
    "prettier": "^3.2.0",
    "style-loader": "^3.3.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.4.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.0.0"
  },
  "engines": {
    "node": ">=18.17.0"
  }
